# Generated by Cargo
# will have compiled files and executables
debug
target

# macOS
.DS_Store

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

.env
.env.bak.*

walrus_cache*

# Generated evaluation output: keep curated summaries and dissertation-facing
# artefacts, but ignore the bulk generated output by default.
walrus-cache-cdn/evaluation_output/*
!walrus-cache-cdn/evaluation_output/README.md
!walrus-cache-cdn/evaluation_output/chapter6_evaluation_revised.tex
!walrus-cache-cdn/evaluation_output/dissertation_figure_table.md
!walrus-cache-cdn/evaluation_output/evaluation.json
!walrus-cache-cdn/evaluation_output/evaluation_interpretation.md
!walrus-cache-cdn/evaluation_output/figure_index.csv
!walrus-cache-cdn/evaluation_output/figure_index.md
!walrus-cache-cdn/evaluation_output/graph_explanations.md
!walrus-cache-cdn/evaluation_output/must_include_report_summary.md
!walrus-cache-cdn/evaluation_output/summary.csv
!walrus-cache-cdn/evaluation_output/warmup_curve.csv
!walrus-cache-cdn/evaluation_output/plots/
walrus-cache-cdn/evaluation_output/plots/*

# dissertation.pdf
.demo_blob_id

# LaTeX build artefacts
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
