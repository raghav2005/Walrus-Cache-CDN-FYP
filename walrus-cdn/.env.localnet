# .env.localnet
NETWORK=localnet
INDEXER_MODE=sui # simulated / sui
SUI_RPC_URL=http://127.0.0.1:9000

# can still read blobs from testnet (no on-chain writes required to read)
# public aggregator
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# publisher - leave unset for localnet cuz uploads generally will require testnet
WALRUS_PUBLISHER_URL=

# for real events later:
# WALRUS_PACKAGE_ID=0x<walrus_testnet_package_id>
# WALRUS_EVENT_MODULE=walrus
